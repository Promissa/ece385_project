{ "Error" "EFIOMGR_IO_BANK_OUTPUTS_VCCIO_INCOMPATIBLE" "VGA_G\[7\] 8 3.3-V LVTTL 3.3V 2.5V " "Pin VGA_G\[7\] with I/O standard assignment 3.3-V LVTTL is incompatible with I/O bank 8. I/O standard 3.3-V LVTTL, has a VCCIO requirement of 3.3V, which incompatible with the I/O bank's VCCIO setting or with other output or bidirectional pins in the I/O bank using a VCCIO requirement of 2.5V. Assign output and bidirectional pins with different VCCIO requirements to different I/O banks, or change the I/O standard assignment for the specified pin to a compatible I/O standard. The Intel FPGA Knowledge Database contains many articles with specific details on how to resolve this error. Visit the Knowledge Database at https://www.altera.com/support/support-resources/knowledge-base/search.html and search for this specific error message number." { { "Info" "IFIOMGR_PIN_IN_BANK_USES_VCCIO" "OTG_ADDR\[1\] 8 2.5V " "Pin OTG_ADDR\[1\] in I/O bank 8 uses VCCIO 2.5V" {  } { { "c:/intelfpga_lite/18.0/quartus/bin64/pin_planner.ppl" "" { PinPlanner "c:/intelfpga_lite/18.0/quartus/bin64/pin_planner.ppl" { OTG_ADDR[1] } } } { "c:/intelfpga_lite/18.0/quartus/bin64/Assignment Editor.qase" "" { Assignment "c:/intelfpga_lite/18.0/quartus/bin64/Assignment Editor.qase" 1 { { 0 "OTG_ADDR\[1\]" } } } } { "fc_galaxian_top.sv" "" { Text "E:/root/2026/385/fc_galaxian_final_project/fc_galaxian_top.sv" 15 0 0 } } { "temporary_test_loc" "" { Generic "E:/root/2026/385/fc_galaxian_final_project/" { { 0 { 0 ""} 0 326 14177 15141 0 0 "" 0 "" "" }  }  } }  } 0 169073 "Pin %1!s! in I/O bank %2!s! uses VCCIO %3!s!" 0 0 "Design Software" 0 -1 1778414178147 ""} { "Info" "IFIOMGR_PIN_IN_BANK_USES_VCCIO" "OTG_CS_N 8 2.5V " "Pin OTG_CS_N in I/O bank 8 uses VCCIO 2.5V" {  } { { "c:/intelfpga_lite/18.0/quartus/bin64/pin_planner.ppl" "" { PinPlanner "c:/intelfpga_lite/18.0/quartus/bin64/pin_planner.ppl" { OTG_CS_N } } } { "c:/intelfpga_lite/18.0/quartus/bin64/Assignment Editor.qase" "" { Assignment "c:/intelfpga_lite/18