--synthesis_resources = 
SUBDESIGN altsyncram_srq1
( 
	address_a[10..0]	:	input;
	address_b[10..0]	:	input;
	byteena_a[3..0]	:	input;
	clock0	:	input;
	data_a[31..0]	:	input;
	data_b[31..0]	:	input;
	q_a[31..0]	:	output;
	q_b[31..0]	:	output;
	wren_a	:	input;
) 

BEGIN 
	ASSERT (0) 
	REPORT "Must connect clock1 port of altsyncram megafunction when using current set of parameters"
	SEVERITY ERROR;
	ASSERT (0) 
	REPORT "Cannot use different clock ports for address_b port and data_b|wren_b|byteena_b(if used) port in altsyncram megafunction"
	SEVERITY ERROR;
END;
--ERROR FILE
